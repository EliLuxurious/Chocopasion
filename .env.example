# ══════════════════════════════════════════════════════
#  Chocopasión — Variables de Entorno
#  Copia este archivo como .env y ajusta los valores
#  NUNCA subas .env al repositorio (está en .gitignore)
# ══════════════════════════════════════════════════════

# ── Flask ─────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=cambia_esta_clave_secreta_en_produccion

# ── Base de Datos MySQL ───────────────────────────────
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=chocopasion2
MYSQL_USER=chocouser
MYSQL_PASSWORD=chocopassword
MYSQL_ROOT_PASSWORD=root_secret

# ── Notas ─────────────────────────────────────────────
# En desarrollo Docker:     MYSQL_HOST=db
# En desarrollo local sin Docker: MYSQL_HOST=127.0.0.1
